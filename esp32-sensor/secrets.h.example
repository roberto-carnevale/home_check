// secrets.h.example
// Template for sensitive information.
// Copy to 'secrets.h' and replace placeholders with actual secrets.
// DO NOT commit 'secrets.h' to version control!

#ifndef SECRETS_H
#define SECRETS_H

#include <pgmspace.h>

// Shared HMAC secret for request signing
// This MUST exactly match the server's SECRET_KEY environment variable.
#define HMAC_SECRET "change-me-to-a-long-random-string"

// Google Trust Services root CA for Cloud Run TLS (copy from browser)
// Run: openssl s_client -connect your-cloud-run-host.run.app:443 -showcerts
// Paste the ROOT CA cert here (the last cert in the chain).
// Using PROGMEM to store this large string in flash memory.
static const char ROOT_CA_CERT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_YOUR_ROOT_CA_HERE
-----END CERTIFICATE-----
)EOF";

#endif // SECRETS_H
